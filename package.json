{
  "name": "@dreki-gg/pi-jira",
  "version": "0.3.0",
  "description": "Jira tools for pi via an authenticated Atlassian CLI (acli) session \u2014 pull ticket context and write concise comments",
  "keywords": [
    "pi-package",
    "pi",
    "jira",
    "atlassian",
    "acli"
  ],
  "author": "Juan Albarran <jalbarrandev@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jalbarrang/pi-jira.git"
  },
  "type": "module",
  "files": [
    "extensions",
    "README.md",
    "CHANGELOG.md",
    "package.json"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "oxlint extensions test",
    "format": "oxfmt --write extensions test",
    "format:check": "oxfmt --check extensions test"
  },
  "pi": {
    "extensions": [
      "./extensions/jira"
    ]
  },
  "devDependencies": {
    "@types/node": "24",
    "bun-types": "^1.3.14",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "typescript": "^6.0.0",
    "@earendil-works/pi-coding-agent": "^0.75.4",
    "typebox": "^1.0.55"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "typebox": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
